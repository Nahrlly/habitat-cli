# Server bind address. This is not the browser/client URL.
HABITAT_API_HOST=0.0.0.0
HABITAT_API_PORT=8787

# Absolute paths on the deployment host.
HABITAT_DATA_DIRECTORY=/var/lib/habitat
HABITAT_DIST_DIRECTORY=/opt/habitat-cli/dist

# Kepler credentials; keep this file outside the checkout and chmod 600.
KEPLER_BASE_URL=https://planet.turingguild.com
KEPLER_PLANET_TOKEN=
